    style StopInit fill:#ffcdd2,stroke:#d32f2f,stroke-width:2px
    style NoReader fill:#fff3cd,stroke:#ff9800,stroke-width:2px
    style UsbGateNote fill:#fff8e1,stroke:#f9a825,stroke-width:2px
    style FailMsg fill:#ffcdd2,stroke:#d32f2f,stroke-width:2px
    style TimeoutMsg fill:#ffcdd2,stroke:#d32f2f,stroke-width:2px
    style DupSkip fill:#fff3cd,stroke:#ff9800,stroke-width:2px
    style Busy fill:#e8eaf6,stroke:#3949ab,stroke-width:2px
    style Connecting fill:#e8eaf6,stroke:#3949ab,stroke-width:2px